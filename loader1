function GetDeviceInfo()
    local ip, device = "0.0.0.0", "ANDROID_DEVICE"
    pcall(function()
        local req = hanz.makeRequest("https://api.ipify.org")
        if req and req.content then ip = req.content end
    end)
    local info = hanz.getTargetInfo()
    if info then
        local arch = info.x64 and "64-bit" or "32-bit"
        local raw_model = info.nativeLibraryDir:match("([^/]+)/lib$") or "DEVICE"
        device = (os.getenv("RO.PRODUCT.BRAND") or "ANDROID"):upper() .. " " .. raw_model:upper() .. " (" .. arch .. ")"
    end
    return ip, device
end

